{# OctoPrint-NASBackup — nasbackup_settings.jinja2 #}

<div id="settings_plugin_nasbackup">

    <div class="nasbackup-master-toggle">
        <input type="checkbox" id="nasbackup_enabled"
               data-bind="checked: settings.enabled">
        <label for="nasbackup_enabled">Enable NAS Backup Plugin</label>
        <span class="muted" style="font-size:11px; font-weight:normal;"
              data-bind="visible: !settings.enabled()">
            (plugin is disabled — no scheduled backups will run)
        </span>
    </div>

    <ul class="nav nav-tabs" id="nasbackup_tabs">
        <li class="active"><a href="#nasbackup_tab_schedule"  data-toggle="tab">Schedule</a></li>
        <li><a href="#nasbackup_tab_nas"       data-toggle="tab">NAS Connection</a></li>
        <li><a href="#nasbackup_tab_options"   data-toggle="tab">Backup Options</a></li>
        <li><a href="#nasbackup_tab_system"    data-toggle="tab">System Files</a></li>
        <li><a href="#nasbackup_tab_retention" data-toggle="tab">Retention</a></li>
        <li><a href="#nasbackup_tab_status"    data-toggle="tab"
               data-bind="click: refreshStatus">Status / Log</a></li>
    </ul>

    <div class="tab-content" style="padding-top:14px;">

        <div class="tab-pane active" id="nasbackup_tab_schedule">
            <p class="nasbackup-section-heading">Backup Schedule</p>

            <div class="control-group">
                <label class="control-label">Schedule type</label>
                <div class="controls">
                    <select data-bind="value: settings.schedule_type">
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly (same weekday)</option>
                        <option value="monthly">Monthly (fixed day-of-month)</option>
                        <option value="disabled">Disabled (manual only)</option>
                    </select>
                </div>
            </div>

            <div class="control-group"
                 data-bind="visible: settings.schedule_type() !== 'disabled'">
                <label class="control-label">Time</label>
                <div class="controls">
                    <input type="time" style="width:110px;"
                           data-bind="value: settings.schedule_time"
                           placeholder="03:00">
                    <span class="help-inline muted">HH:MM — uses the device local timezone</span>
                </div>
            </div>

            <div class="control-group"
                 data-bind="visible: settings.schedule_type() === 'weekly'">
                <label class="control-label">Day of week</label>
                <div class="controls">
                    <select data-bind="value: settings.schedule_day_of_week">
                        <option value="0">Monday</option>
                        <option value="1">Tuesday</option>
                        <option value="2">Wednesday</option>
                        <option value="3">Thursday</option>
                        <option value="4">Friday</option>
                        <option value="5">Saturday</option>
                        <option value="6">Sunday</option>
                    </select>
                </div>
            </div>

            <div class="control-group"
                 data-bind="visible: settings.schedule_type() === 'monthly'">
                <label class="control-label">Day of month</label>
                <div class="controls">
                    <input type="number" min="1" max="28" style="width:70px;"
                           data-bind="value: settings.schedule_day_of_month">
                    <span class="help-inline muted">1-28 (use 28 or lower to avoid month-end issues)</span>
                </div>
            </div>

            <div class="control-group">
                <div class="controls">
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.only_when_idle">
                        Only run backup when printer is <strong>idle</strong> (skip if printing or paused)
                    </label>
                </div>
            </div>
        </div>

        <div class="tab-pane" id="nasbackup_tab_nas">
            <p class="nasbackup-section-heading">Transfer Mode</p>

            <div class="control-group">
                <label class="control-label">Mode</label>
                <div class="controls">
                    <select data-bind="value: settings.transfer_mode">
                        <option value="local">Local path (fstab / NFS / pre-mounted share)</option>
                        <option value="smbclient">SMB via smbclient (no mount needed)</option>
                    </select>
                </div>
            </div>

            <div data-bind="visible: settings.transfer_mode() === 'local'">
                <div class="control-group">
                    <label class="control-label">Local backup path</label>
                    <div class="controls">
                        <input type="text" class="input-block-level"
                               data-bind="value: settings.local_path"
                               placeholder="/mnt/octoprint_backup">
                        <span class="help-block muted">
                            Must be mounted and writable by the OctoPrint user.
                            See README for an example /etc/fstab entry.
                        </span>
                    </div>
                </div>
            </div>

            <div data-bind="visible: settings.transfer_mode() === 'smbclient'">
                <p class="nasbackup-section-heading" style="margin-top:12px;">SMB Credentials</p>

                <div class="control-group">
                    <label class="control-label">Host / IP</label>
                    <div class="controls">
                        <input type="text" style="width:220px;"
                               data-bind="value: settings.smb_host"
                               placeholder="192.168.1.11">
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Share name</label>
                    <div class="controls">
                        <input type="text" style="width:220px;"
                               data-bind="value: settings.smb_share"
                               placeholder="backup">
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Sub-directory</label>
                    <div class="controls">
                        <input type="text" style="width:220px;"
                               data-bind="value: settings.smb_subdir"
                               placeholder="OctoPrint">
                        <span class="help-inline muted">Created automatically inside the share root</span>
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Username</label>
                    <div class="controls">
                        <input type="text" style="width:220px;" autocomplete="off"
                               data-bind="value: settings.smb_username">
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Password</label>
                    <div class="controls">
                        <input type="password" style="width:220px;" autocomplete="new-password"
                               data-bind="value: settings.smb_password">
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Domain <small class="muted">(optional)</small></label>
                    <div class="controls">
                        <input type="text" style="width:180px;"
                               data-bind="value: settings.smb_domain"
                               placeholder="WORKGROUP">
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">SMB version</label>
                    <div class="controls">
                        <select data-bind="value: settings.smb_version" style="width:100px;">
                            <option value="2.0">2.0</option>
                            <option value="2.1">2.1</option>
                            <option value="3.0">3.0</option>
                            <option value="3.1.1">3.1.1</option>
                        </select>
                    </div>
                </div>
            </div>

            <hr style="margin:14px 0 10px;">
            <div class="control-group">
                <div class="controls">
                    <button class="btn btn-small"
                            data-bind="click: testConnection, enable: !testBusy()">
                        <i class="fas fa-plug"></i>
                        <!-- ko ifnot: testBusy -->Test Connection<!-- /ko -->
                        <!-- ko if: testBusy --><i class="fas fa-spinner fa-spin"></i> Testing...<!-- /ko -->
                    </button>

                    <!-- ko if: testResult -->
                    <div class="nasbackup-test-result"
                         data-bind="css: testResult().success ? 'ok' : 'err'">
                        <!-- ko if: testResult().success -->
                        <i class="fas fa-check-circle"></i>
                        <!-- /ko -->
                        <!-- ko ifnot: testResult().success -->
                        <i class="fas fa-times-circle"></i>
                        <!-- /ko -->
                        <span data-bind="text: testResult().message"></span>
                    </div>
                    <!-- /ko -->
                </div>
            </div>
        </div>

        <div class="tab-pane" id="nasbackup_tab_options">
            <p class="nasbackup-section-heading">OctoPrint ZIP Backup</p>

            <div class="control-group">
                <div class="controls">
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.exclude_timelapse">
                        Exclude <strong>timelapse</strong> files (recommended — can be very large)
                    </label>
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.exclude_uploads">
                        Exclude <strong>uploads</strong> (GCODE files)
                    </label>
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Local ZIP keep count</label>
                <div class="controls">
                    <input type="number" min="1" max="99" style="width:70px;"
                           data-bind="value: settings.local_keep_count">
                    <span class="help-inline muted">
                        OctoPrint backup ZIPs kept on the SD card — older ones deleted to reduce write wear.
                    </span>
                </div>
            </div>

            <hr style="margin:14px 0 10px;">
            <p class="nasbackup-section-heading">Server / Printer Name</p>

            <div class="control-group">
                <div class="controls">
                    <label class="radio">
                        <input type="radio" name="nasbackup_server_name_mode" value="true"
                               data-bind="checked: settings.server_name_auto">
                        Auto-detect from OctoPrint appearance name (falls back to hostname)
                    </label>
                    <label class="radio">
                        <input type="radio" name="nasbackup_server_name_mode" value="false"
                               data-bind="checked: settings.server_name_auto">
                        Manual:
                        <input type="text" style="width:160px; margin-left:6px;"
                               data-bind="value: settings.server_name_manual,
                                          enable: settings.server_name_auto() === 'false' || settings.server_name_auto() === false"
                               placeholder="MyPrinter">
                    </label>
                </div>
            </div>

            <hr style="margin:14px 0 10px;">

            <div class="control-group">
                <div class="controls">
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.copy_log_to_nas">
                        Copy backup log to NAS alongside each snapshot
                    </label>
                </div>
            </div>
        </div>

        <div class="tab-pane" id="nasbackup_tab_system">
            <p class="nasbackup-section-heading">System Files Backup</p>

            <div class="control-group">
                <div class="controls">
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.system_backup_enabled">
                        <strong>Enable system files backup</strong>
                    </label>
                </div>
            </div>

            <div data-bind="visible: settings.system_backup_enabled">
                <div class="control-group">
                    <label class="control-label">Paths to back up</label>
                    <div class="controls">
                        <textarea rows="10" class="input-block-level"
                                  data-bind="value: settings.system_backup_items"
                                  style="font-family:monospace; font-size:12px;"></textarea>
                        <span class="help-block muted">
                            One path per line. Files and directories are both supported.
                            For <strong>smbclient</strong> mode they are packed into
                            <code>system_backup.tar.gz</code> and uploaded.
                            For <strong>local</strong> mode they are copied preserving directory structure.
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane" id="nasbackup_tab_retention">
            <p class="nasbackup-section-heading">GFS Retention Policy</p>

            <div class="control-group">
                <div class="controls">
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: settings.retention_enabled">
                        <strong>Enable automatic pruning</strong> of old snapshots on the NAS
                    </label>
                </div>
            </div>

            <div data-bind="visible: settings.retention_enabled">
                <table class="table table-condensed" style="width:auto; margin-top:10px;">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th style="text-align:center;">Keep</th>
                            <th style="padding-left:12px;">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Daily</strong></td>
                            <td style="text-align:center;">
                                <input type="number" min="0" max="365" style="width:65px;"
                                       data-bind="value: settings.keep_daily">
                            </td>
                            <td style="padding-left:12px; color:#666;">Keep one snapshot per day for this many days</td>
                        </tr>
                        <tr>
                            <td><strong>Weekly</strong></td>
                            <td style="text-align:center;">
                                <input type="number" min="0" max="104" style="width:65px;"
                                       data-bind="value: settings.keep_weekly">
                            </td>
                            <td style="padding-left:12px; color:#666;">Keep one per ISO week for this many weeks</td>
                        </tr>
                        <tr>
                            <td><strong>Monthly</strong></td>
                            <td style="text-align:center;">
                                <input type="number" min="0" max="120" style="width:65px;"
                                       data-bind="value: settings.keep_monthly">
                            </td>
                            <td style="padding-left:12px; color:#666;">Keep one per month for this many months</td>
                        </tr>
                        <tr>
                            <td><strong>Yearly</strong></td>
                            <td style="text-align:center;">
                                <input type="number" min="0" max="50" style="width:65px;"
                                       data-bind="value: settings.keep_yearly">
                            </td>
                            <td style="padding-left:12px; color:#666;">Keep one per year for this many years</td>
                        </tr>
                    </tbody>
                </table>
                <p class="muted" style="font-size:11px; margin-top:4px;">
                    Snapshots are evaluated newest-first. A snapshot is kept if it is the first (newest)
                    in its time window. Everything else is deleted.
                </p>
            </div>
        </div>

        <div class="tab-pane" id="nasbackup_tab_status">
            <p class="nasbackup-section-heading">Current Status</p>

            <table class="table table-condensed" style="width:auto; margin-bottom:10px;">
                <tbody>
                    <tr>
                        <td><strong>Status</strong></td>
                        <td>
                            <span class="nasbackup-status-badge"
                                  data-bind="text: statusLabel, css: statusClass"></span>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Message</strong></td>
                        <td><span data-bind="text: lastStatus().message || '-'"></span></td>
                    </tr>
                    <tr>
                        <td><strong>Last run</strong></td>
                        <td>
                            <!-- ko if: lastStatus().time -->
                            <span data-bind="text: lastStatus().time"></span>
                            <!-- /ko -->
                            <!-- ko ifnot: lastStatus().time -->
                            <span class="muted">-</span>
                            <!-- /ko -->
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Next scheduled</strong></td>
                        <td>
                            <!-- ko if: nextRun -->
                            <span data-bind="text: nextRun"></span>
                            <!-- /ko -->
                            <!-- ko ifnot: nextRun -->
                            <span class="muted">Not scheduled</span>
                            <!-- /ko -->
                        </td>
                    </tr>
                </tbody>
            </table>

            <div style="margin-bottom:14px;">
                <button class="btn btn-primary btn-small"
                        data-bind="click: triggerBackup,
                                   enable: !triggerBusy() && !backupRunning() && settings.enabled()">
                    <!-- ko if: backupRunning -->
                    <i class="fas fa-spinner fa-spin"></i> Backup running...
                    <!-- /ko -->
                    <!-- ko ifnot: backupRunning -->
                    <i class="fas fa-play"></i> Run Backup Now
                    <!-- /ko -->
                </button>
                &nbsp;
                <button class="btn btn-small" data-bind="click: refreshStatus">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
                &nbsp;
                <button class="btn btn-small btn-danger" data-bind="click: clearLogs">
                    <i class="fas fa-trash"></i> Clear log
                </button>
            </div>

            <p class="nasbackup-section-heading">Backup Log</p>
            <div id="nasbackup_log_area" class="nasbackup-log"
                 data-bind="foreach: logs">
                <div data-bind="text: $data, css: $parent.logLineClass($data)"></div>
            </div>

            <!-- ko if: logs().length === 0 -->
            <p class="muted" style="font-size:12px; margin-top:6px;">
                No log entries yet. Run a backup or check if the plugin is enabled.
            </p>
            <!-- /ko -->
        </div>

    </div>
</div>